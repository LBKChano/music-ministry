{
  "expo": {
    "name": "Music Ministry",
    "slug": "music-ministry",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-btg.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app-icon-btg.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A8A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-btg.png",
        "backgroundColor": "#1E3A8A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/app-icon-asi.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "scheme": "musicministry",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://nucffxkqp3vv9chpnxeb3a3fcnb99vdb.app.specular.dev",
      "eas": {
        "projectId": "a500e23e-d75d-44a5-bf0c-6baaf4d67839"
      }
    }
  }
}