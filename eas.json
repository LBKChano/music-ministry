{
  "cli": {
    "version": ">= 5.9.3"
  },
  "build": {
    "development": {
      "cache": { "disabled": true },
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium",
        "buildConfiguration": "Debug",
        "config": "ios-simulator-pre-install.yml"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "cache": { "disabled": true },
      "distribution": "internal",
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "resourceClass": "m-medium",
        "config": "ios-pre-install.yml"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "cache": { "disabled": true },
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "ios": {
        "buildConfiguration": "Release",
        "resourceClass": "m-medium",
        "autoIncrement": true,
        "config": "ios-pre-install.yml"
      },
      "android": {
        "buildType": "apk",
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}